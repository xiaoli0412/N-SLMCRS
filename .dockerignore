# Docker 构建上下文排除清单

# 已编译产物（容器内重新编译）
bin/
*.exe

# 本地发布产物与前端构建输出（容器内由多阶段构建产生）
dist/
web/dist/
internal/entry/dist/

# Rust 内核构建产物（229MB，绝不该进上下文）
kernel-rs/target/

# 本地数据库与备份
data/
*.db
*.db-wal
*.db-shm
data/backups/

# 环境与密钥（绝不进镜像）
.env
.env.local
.env.*.local

# Git / IDE
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp

# 文档与脚本（非构建依赖）
docs/
deploy/
*.md

# 前端依赖与缓存
web/node_modules/
web/.vite/

# 测试与临时
**/*_test.go
**/testdata/
tmp/
*.log
