# ════════════════════════════════════════════════════════════════════════
# N-SLMCRS 网关配置示例
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中排除）
# ════════════════════════════════════════════════════════════════════════

# ─── 服务 ────────────────────────────────────────────────────────────────
# HTTP 监听端口
PORT=8787

# 管理 API 鉴权令牌（增删上游 Key、签发凭证等敏感操作的口令）
# 默认初始值 admin：首次登录后将强制修改并写入 bcrypt 哈希，旧默认令牌即失效。
# 生成强令牌：openssl rand -hex 16
ADMIN_TOKEN=admin

# ─── NVIDIA 上游 ─────────────────────────────────────────────────────────
# 测试用 NVIDIA Studio API Key（启动时自动注册为第一个上游密钥）
# 生产环境请通过管理面板（/keys）逐个添加多个账号的密钥
NVIDIA_TEST_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 对话 / 补全 / 模型列表 上游域名
NVIDIA_CHAT_BASE_URL=https://integrate.api.nvidia.com/v1

# 向量嵌入 / 重排序 上游域名（NVIDIA 采用了独立域名）
NVIDIA_RETRIEVAL_BASE_URL=https://ai.api.nvidia.com/v1

# 官方默认每 Key RPM 上限（NVIDIA 免费层 40 RPM，按官方搜索结果）
DEFAULT_RPM=40

# 单次上游请求超时
UPSTREAM_TIMEOUT=120s

# 模型目录自动同步间隔（每 24h 从 /v1/models 软更新一次）
MODEL_SYNC_INTERVAL=24h

# ─── 调度器 ──────────────────────────────────────────────────────────────
# 默认 N 路并发度（热模型同时发起的请求数，先到先得）
DEFAULT_CONCURRENCY=5

# 最大并发上限（防止突发流量失控）
MAX_CONCURRENCY=10

# 整体请求超时（含多路重试）
SCHEDULER_TIMEOUT=180s

# 连续失败多少次触发熔断
CIRCUIT_THRESHOLD=5

# 熔断初始冷却时长（指数退避：30s→60s→120s，封顶 10min）
CIRCUIT_COOLDOWN=30s

# ─── 数据 / 存储 ─────────────────────────────────────────────────────────
# SQLite 数据库文件路径（自动创建父目录）
SQLITE_PATH=data/nslmcrs.db

# ─── 鉴权 ────────────────────────────────────────────────────────────────
# 签发给下游客户端的凭证前缀
DOWNSTREAM_KEY_PREFIX=sk-nv-

# ─── 运行模式 ────────────────────────────────────────────────────────────
# Gin 运行模式（release / debug），生产用 release
GIN_MODE=release
