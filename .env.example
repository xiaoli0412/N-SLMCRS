# ════════════════════════════════════════════════════════════════════════
# N-SLMCRS 网关配置示例
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中排除）
# ════════════════════════════════════════════════════════════════════════

# ─── 服务 ────────────────────────────────────────────────────────────────
# HTTP 监听端口
PORT=8787

# 管理 API 鉴权令牌（增删上游 Key、签发凭证等敏感操作的口令）
# 默认初始值 ADMIN：首次登录后将强制修改并写入 bcrypt 哈希，旧默认令牌即失效。
# 改密前所有受保护的管理 API 将被锁定（仅 login / change-password 可用）。
# 生成强令牌：openssl rand -hex 16
ADMIN_TOKEN=ADMIN

# ─── NVIDIA 上游 ─────────────────────────────────────────────────────────
# 测试用 NVIDIA Studio API Key（启动时自动注册为第一个上游密钥）
# 生产环境请通过管理面板（/keys）逐个添加多个账号的密钥
NVIDIA_TEST_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 对话 / 补全 / 模型列表 上游域名
NVIDIA_CHAT_BASE_URL=https://integrate.api.nvidia.com/v1

# 向量嵌入 / 重排序 上游域名（NVIDIA 采用了独立域名）
NVIDIA_RETRIEVAL_BASE_URL=https://ai.api.nvidia.com/v1

# 官方默认每 Key RPM 上限（NVIDIA 免费层 40 RPM，按官方搜索结果）
DEFAULT_RPM=40

# 单次上游请求超时
UPSTREAM_TIMEOUT=120s

# 模型目录自动同步间隔（每 24h 从 /v1/models 软更新一次）
MODEL_SYNC_INTERVAL=24h

# ─── 调度器 ──────────────────────────────────────────────────────────────
# 默认 N 路并发度（热模型同时发起的请求数，先到先得）
DEFAULT_CONCURRENCY=5

# 最大并发上限（防止突发流量失控）
MAX_CONCURRENCY=10

# 整体请求超时（含多路重试）
SCHEDULER_TIMEOUT=180s

# 连续失败多少次触发熔断
CIRCUIT_THRESHOLD=5

# 熔断初始冷却时长（指数退避：30s→60s→120s，封顶 10min）
CIRCUIT_COOLDOWN=30s

# ─── 数据 / 存储 ─────────────────────────────────────────────────────────
# SQLite 数据库文件路径（自动创建父目录）
SQLITE_PATH=data/nslmcrs.db

# ─── 鉴权 ────────────────────────────────────────────────────────────────
# 签发给下游客户端的凭证前缀
DOWNSTREAM_KEY_PREFIX=sk-nv-

# ─── 运行模式 ────────────────────────────────────────────────────────────
# Gin 运行模式（release / debug），生产用 release
GIN_MODE=release

# ─── Auto-Pilot LLM 引擎（可选）──────────────────────────────────────────
# 三者齐全时，LLM 决策引擎将调用真实大模型；留空则回退确定性 stub（仍可产出动作）
# LLM_BASE_URL 指向网关自身转发地址（或任意 OpenAI 兼容端点）
# LLM_API_KEY  为下游凭证（sk-nv-xxx，需在管理面板先签发）
# LLM_MODEL    为目标模型，如 meta/llama-3.1-8b-instruct
# LLM_BASE_URL=http://localhost:8787/v1
# LLM_API_KEY=sk-nv-xxxxxxxx
# LLM_MODEL=meta/llama-3.1-8b-instruct

# ─── Rust 内核 sidecar（可选，v0.7）──────────────────────────────────────
# Auto-Pilot 的 Holt-Winters 预测 + 可用度聚合委托 Rust sidecar 计算；
# 不可达时自动降级回内置 Go 实现（无单点依赖）。
# docker compose 已含 kernel 服务，容器内默认 http://kernel:8790。
# KERNEL_URL=http://kernel:8790
# 设为 1 则完全禁用，强制走纯 Go：
# KERNEL_DISABLE=1

# ─── 数据库备份（v0.8）──────────────────────────────────────────────────
# 用 VACUUM INTO 产出事务一致快照（WAL 安全），按保留数轮转删最旧。
# docker compose 已将 BACKUP_DIR 指向持久卷 /data/backups，容器重建后备份仍在。
# BACKUP_DIR=/data/backups
# 自动备份间隔（默认 24h；设为 0 或留空则禁用定时，仅手动触发）
# BACKUP_INTERVAL=24h
# 保留最近多少份（默认 7；设为 0 则不自动清理）
# BACKUP_RETENTION=7

# ─── 日志（v0.9 / v0.10）────────────────────────────────────────────────
# 日志级别：debug / info / warn / error（默认 info）
# LOG_LEVEL=info
# 日志格式：json / text（默认 json，结构化便于日志中心检索）
# LOG_FORMAT=json
# 日志文件路径（v0.10）：非空则额外落盘到该文件（追加，自动建目录）。
# 建议指向 D 盘持久路径，避免日志写满 C 盘系统盘；留空则仅 stdout + app_logs 表。
# LOG_FILE=D:/nslmcrs/logs/gateway.log

# ─── 模型级健康扫描与熔断（v0.9）──────────────────────────────────────
# 后台周期性对每个模型按其能力遍历所有 NVIDIA 推理接口各探 N 次，
# 按成功率判定 closed/open/permanent。失败模型从 /v1/models 隐藏并返回熔断说明。
# 全部参数均可在管理面板 /settings 运行时热改（modelhealth.* 前缀）。

# 每个接口每轮探测次数（默认 3）
# MODEL_HEALTH_PROBE_COUNT=3
# 同轮探测之间的间隔（默认 2s，避免突发）
# MODEL_HEALTH_PROBE_INTERVAL=2s
# 全量扫描周期（默认 30m）
# MODEL_HEALTH_SWEEP_INTERVAL=30m
# 永久熔断地板：低于此成功率计一次坏扫描（默认 30）
# MODEL_HEALTH_SUCCESS_RATE_FLOOR=30
# 临时熔断阈值：低于此但≥Floor 转 open（默认 80）
# MODEL_HEALTH_SUCCESS_RATE_THRESHOLD=80
# 连续坏扫描次数达此值 → 永久熔断（默认 3）
# MODEL_HEALTH_BAD_SWEEP_TO_PERMANENT=3
# open 态初始冷却（指数退避起始，封顶 10min；默认 30s）
# MODEL_HEALTH_COOLDOWN_BASE=30s

